# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ----------------------------------------------------------------
# AI provider for /api/clean.
# Default is "gemini" (free tier on Google AI Studio).
# Set to "anthropic" once you have an ANTHROPIC_API_KEY.
# ----------------------------------------------------------------
AI_PROVIDER=gemini

# Gemini — Google AI Studio. Free tier, get a key at:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the Gemini model. Default is gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic — only used when AI_PROVIDER=anthropic.
# Create a key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe secret key (server-side only). Not used by the app yet —
# uncomment when server-side Stripe code is added.
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Payment Link URL. NEXT_PUBLIC_ prefix exposes it to the browser.
# Create one at https://dashboard.stripe.com/payment-links
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_dRmfZb5oQcbg1P48aX7g400
